<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net9.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
	  <None Remove="data\haarcascade_frontalface_default.xml" />
	  <None Remove="person.jpg" />
	</ItemGroup>

	<ItemGroup>
	  <Content Include="data\haarcascade_frontalface_default.xml">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	  <Content Include="person.jpg">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="Emgu.CV" Version="4.12.0.5764" />
	  <PackageReference Include="Emgu.CV.runtime.windows" Version="4.12.0.5764" />
	</ItemGroup>

</Project>